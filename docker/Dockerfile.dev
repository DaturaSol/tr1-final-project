# ./docker/Dockerfile.dev
# Developer docker image
FROM python:3.12-slim-bookworm

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev \
    git curl \
    ca-certificates \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install uv from the official multi-arch image
COPY --from=ghcr.io/astral-sh/uv:latest \
    /uv /uvx /usr/local/bin/

# Tell uv to put the venv at /workspace/.venv
ENV UV_PROJECT_ENVIRONMENT=/workspace/.venv \
    UV_LINK_MODE=copy \
    PATH="/workspace/.venv/bin:$PATH"

# Docker CLI + Compose + Buildx
COPY --from=docker:cli /usr/local/bin/docker /usr/local/bin/docker
COPY --from=docker/compose-bin:latest /docker-compose /usr/libexec/docker/cli-plugins/docker-compose
COPY --from=docker/buildx-bin:latest  /buildx        /usr/libexec/docker/cli-plugins/docker-buildx
RUN ln -s /usr/libexec/docker/cli-plugins/docker-compose /usr/local/bin/docker-compose

# Node.js 22 LTS + pnpm via Corepack
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/* \
    && corepack enable \
    && corepack prepare pnpm@latest --activate
# Install claude
RUN npm install -g @anthropic-ai/claude-code

WORKDIR /workspace